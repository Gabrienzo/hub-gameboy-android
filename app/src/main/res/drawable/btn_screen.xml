<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/retro_background" />
            <stroke android:width="4dp" android:color="@color/retro_accent" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/retro_accent" />
            <stroke android:width="4dp" android:color="@color/retro_shadow" />
        </shape>
    </item>
</selector>