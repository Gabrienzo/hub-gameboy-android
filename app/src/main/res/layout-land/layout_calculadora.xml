<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gb_body">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:background="@color/gb_screen_border"
        android:padding="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp"
            android:background="@color/retro_background"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtHistorico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.7"
                android:fontFamily="@font/press_start_2p"
                android:gravity="end"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/retro_accent"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txtResultado"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/press_start_2p"
                android:gravity="end|bottom"
                android:padding="8dp"
                android:shadowColor="@color/retro_shadow"
                android:shadowDx="5"
                android:shadowDy="5"
                android:shadowRadius="1"
                android:text="@string/zero"
                android:textColor="@color/retro_accent"
                android:textSize="24sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btnSin"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/sin"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="11sp" />

                        <android.widget.Button
                            android:id="@+id/btnCos"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/cos"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btnTan"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/tan"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="11sp" />

                        <android.widget.Button
                            android:id="@+id/btnRaiz"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/raiz"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_margin="4dp"
                    android:background="@color/retro_shadow" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btnClear"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/erase"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnBackspace"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/delete"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnDividir"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/divide"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnMultiplicar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/multiplicar"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btn7"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/sete"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btn8"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/oito"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btn9"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/nove"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnSubtrair"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/menos"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btn4"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/quatro"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btn5"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/cinco"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btn6"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/seis"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnSomar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/mais"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btn1"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/um"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btn2"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/dois"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btn3"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/tres"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnIgual"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/igual"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <android.widget.Button
                            android:id="@+id/btn0"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="2"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/zero"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <android.widget.Button
                            android:id="@+id/btnPonto"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_margin="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/btn_screen"
                            android:fontFamily="@font/press_start_2p"
                            android:text="@string/ponto"
                            android:textColor="@color/text_retro_selector"
                            android:textSize="12sp" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <android.widget.Button
        android:id="@+id/btnVoltarMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:background="@drawable/btn_gameboy"
        android:fontFamily="@font/press_start_2p"
        android:padding="12dp"
        android:text="@string/btnBackMenu"
        android:textColor="@color/white"
        android:textSize="14sp" />

</RelativeLayout>