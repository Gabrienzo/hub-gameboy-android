<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gb_body"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="64dp"
        android:background="@color/gb_screen_border"
        android:padding="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="13dp"
            android:background="@color/retro_background"

            >

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/timeA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Time A"
                    android:textSize="24sp"
                    android:textColor="@color/retro_accent"
                    android:fontFamily="@font/press_start_2p"
                    android:shadowColor="@color/retro_shadow"
                    android:shadowDx="7"
                    android:shadowDy="7"
                    android:shadowRadius="1"/>

                <TextView
                    android:id="@+id/placarTimeA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="4dp"
                    android:text="0"
                    android:textSize="80sp"
                    android:textColor="@color/retro_accent"
                    android:fontFamily="@font/press_start_2p"
                    android:shadowColor="@color/retro_shadow"
                    android:shadowDx="10"
                    android:shadowDy="10"
                    android:shadowRadius="1"/>

                <android.widget.Button
                    android:id="@+id/tresPontosA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="15sp"
                    android:text="+3 PONTOS" />

                <android.widget.Button
                    android:id="@+id/doisPontosA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="15sp"
                    android:text="+2 PONTOS" />

                <android.widget.Button
                    android:id="@+id/tiroLivreA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="15sp"
                    android:text="TIRO LIVRE" />

            </LinearLayout>

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/retro_shadow"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="13dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/timeB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Time B"
                    android:textSize="24sp"
                    android:textColor="@color/retro_accent"
                    android:fontFamily="@font/press_start_2p"
                    android:shadowColor="@color/retro_shadow"
                    android:shadowDx="7"
                    android:shadowDy="7"
                    android:shadowRadius="1"/>

                <TextView
                    android:id="@+id/placarTimeB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="4dp"
                    android:text="0"
                    android:textSize="80sp"
                    android:textColor="@color/retro_accent"
                    android:fontFamily="@font/press_start_2p"
                    android:shadowColor="@color/retro_shadow"
                    android:shadowDx="10"
                    android:shadowDy="10"
                    android:shadowRadius="1"/>

                <android.widget.Button
                    android:id="@+id/tresPontosB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="15sp"
                    android:text="+3 PONTOS" />

                <android.widget.Button
                    android:id="@+id/doisPontosB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="15sp"
                    android:text="+2 PONTOS" />

                <android.widget.Button
                    android:id="@+id/tiroLivreB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="15sp"
                    android:text="TIRO LIVRE" />
            </LinearLayout>

        </LinearLayout>

</LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        android:gravity="center">

        <android.widget.Button
            android:id="@+id/reiniciarPartida"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="16dp"
            android:background="@drawable/btn_gameboy"
            android:textColor="@color/gb_contrast"
            android:fontFamily="@font/press_start_2p"
            android:textSize="14sp"
            android:text="REINICIAR PARTIDA" />

        <android.widget.Button
            android:id="@+id/btnVoltarMenu"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@drawable/btn_gameboy"
            android:textColor="@color/gb_contrast"
            android:fontFamily="@font/press_start_2p"
            android:textSize="14sp"
            android:text="VOLTAR AO MENU" />

    </LinearLayout>
</RelativeLayout>