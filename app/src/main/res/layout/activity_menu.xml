<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gb_body"
    tools:context=".MenuActivity">

    <android.widget.Button
        android:id="@+id/btnTema"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:background="@drawable/btn_gameboy"
        android:fontFamily="@font/press_start_2p"
        android:text="TEMA"
        android:textColor="@color/white"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="370dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="90dp"
        android:background="@color/gb_screen_border"
        android:padding="1dp"
        android:layout_centerHorizontal="true"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="570dp"
            android:orientation="vertical"
            android:layout_margin="13dp"
            android:background="@color/retro_background"
            android:gravity="center"
            >

            <TextView
                android:id="@+id/menu_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="10dp"
                android:text="Hub GameBoy"
                android:textSize="25sp"
                android:textColor="@color/retro_accent"
                android:fontFamily="@font/press_start_2p"
                android:shadowColor="@color/retro_shadow"
                android:shadowDx="7"
                android:shadowDy="6"
                android:shadowRadius="1"/>

            <TextView
                android:id="@+id/menu_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="4dp"
                android:text="Selecione a aplicação"
                android:textSize="25sp"
                android:textColor="@color/retro_accent"
                android:fontFamily="@font/press_start_2p"
                android:shadowColor="@color/retro_shadow"
                android:shadowDx="7"
                android:shadowDy="6"
                android:shadowRadius="1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="32dp">

                <android.widget.Button
                    android:id="@+id/btn_seta_esquerda"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="20sp"
                    android:text="&lt;" />

                <android.widget.Button
                    android:id="@+id/icon_app_menu"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="23sp"
                    android:text="0 : 0\n\nPlacar" />

                <android.widget.Button
                    android:id="@+id/btn_seta_direita"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="20sp"
                    android:text="&gt;" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>