<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gb_body">

    <LinearLayout
        android:layout_width="370dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="64dp"
        android:background="@color/gb_screen_border"
        android:padding="1dp"
        android:layout_centerHorizontal="true"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="500dp"
            android:orientation="vertical"
            android:layout_margin="13dp"
            android:background="@color/retro_background"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtHistorico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/retro_accent"
                android:alpha="0.7"
                android:fontFamily="@font/press_start_2p"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/txtResultado"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:gravity="end|bottom"
                android:text="0"
                android:textSize="32sp"
                android:textColor="@color/retro_accent"
                android:fontFamily="@font/press_start_2p"
                android:shadowColor="@color/retro_shadow"
                android:shadowDx="5"
                android:shadowDy="5"
                android:shadowRadius="1"
                android:padding="8dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <android.widget.Button
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="C" />

                <android.widget.Button
                    android:id="@+id/btnBackspace"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="DEL" />

                <android.widget.Button
                    android:id="@+id/btnDividir"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="÷" />

                <android.widget.Button
                    android:id="@+id/btnMultiplicar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="X" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <android.widget.Button
                    android:id="@+id/btn7"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="7" />

                <android.widget.Button
                    android:id="@+id/btn8"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="8" />

                <android.widget.Button
                    android:id="@+id/btn9"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="9" />

                <android.widget.Button
                    android:id="@+id/btnSubtrair"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="-" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <android.widget.Button
                    android:id="@+id/btn4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="4" />

                <android.widget.Button
                    android:id="@+id/btn5"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="5" />

                <android.widget.Button
                    android:id="@+id/btn6"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="6" />

                <android.widget.Button
                    android:id="@+id/btnSomar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="+" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <android.widget.Button
                    android:id="@+id/btn1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="1" />

                <android.widget.Button
                    android:id="@+id/btn2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="2" />

                <android.widget.Button
                    android:id="@+id/btn3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="3" />

                <android.widget.Button
                    android:id="@+id/btnIgual"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="=" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <android.widget.Button
                    android:id="@+id/btn0"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="0" />

                <android.widget.Button
                    android:id="@+id/btnPonto"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/btn_screen"
                    android:textColor="@color/text_retro_selector"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    android:text="." />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <android.widget.Button
        android:id="@+id/btnVoltarMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_margin="32dp"
        android:padding="16dp"
        android:background="@drawable/btn_gameboy"
        android:textColor="@color/gb_contrast"
        android:fontFamily="@font/press_start_2p"
        android:textSize="18sp"
        android:text="VOLTAR AO MENU" />

</RelativeLayout>